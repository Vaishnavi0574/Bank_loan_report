      <aliases enabled='yes' />
      <column caption='Avg DTI' datatype='real' name='[Avg Int Rate (copy)_0896421928849427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([dti])' />
      </column>
      <column caption='Total Loan Applications' datatype='integer' name='[Calculation_0896421918453760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;[id]&#13;&#10;)' />
      </column>
      <column caption='MTD Total Loan Applications' datatype='integer' name='[Calculation_0896421918650369]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;    IF DATETRUNC(&apos;month&apos;, [issue_date]) = DATETRUNC(&apos;month&apos;, { MAX([issue_date]) })&#13;&#10;    AND [issue_date] &lt;= { MAX([issue_date]) }&#13;&#10;    THEN [id]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='Avg Int Rate' datatype='real' name='[Calculation_0896421922471948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([int_rate])' />
      </column>
      <column caption='MTD Avg Int Rate' datatype='real' name='[Calculation_0896421922750477]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF DATETRUNC(&apos;month&apos;, [issue_date]) = DATETRUNC(&apos;month&apos;, { MAX([issue_date]) })&#13;&#10;    AND [issue_date] &lt;= { MAX([issue_date]) }&#13;&#10;    THEN [int_rate]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='PMTD Avg Int Rate' datatype='real' name='[Calculation_0896421922844686]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF DATETRUNC(&apos;month&apos;, [issue_date]) &#13;&#10;        = DATETRUNC(&apos;month&apos;, DATEADD(&apos;month&apos;, -1, { MAX([issue_date]) }))&#13;&#10;    AND DAY([issue_date]) &lt;= DAY({ MAX([issue_date]) })&#13;&#10;    THEN [int_rate]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='MoM Avg Int Rate' datatype='real' name='[Calculation_0896421923024911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0896421922844686] = 0 THEN 0&#13;&#10;ELSE&#13;&#10;(&#13;&#10;    [Calculation_0896421922750477]&#13;&#10;    -&#13;&#10;    [Calculation_0896421922844686]&#13;&#10;)&#13;&#10;/&#13;&#10;[Calculation_0896421922844686]&#13;&#10;END' />
      </column>
      <column caption='Good Loan %' datatype='real' name='[Calculation_0896422004949026]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(if [Loan Status (group)]=&apos;Good Loan&apos; THEN [id]END)/COUNT([id])' />
      </column>
      <column caption='Good Loan Applications' datatype='integer' name='[Calculation_0896422006599715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(if [Loan Status (group)]=&apos;Good Loan&apos; then [id] END)' />
      </column>
      <column caption='Dynamic Measure' datatype='integer' name='[Calculation_0896422069583914]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  [Parameters].[Parameter 1]=&apos;Total Loan Applications&apos; THEN [Calculation_0896421918453760]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Total Funded Amount&apos; THEN [Total Loan Applications (copy)_0896421920137220]&#13;&#10;ELSEIF [Parameters].[Parameter 1]=&apos;Total Recieved Amount&apos; THEN [Total Loan Applications (copy)_0896421921394699]&#13;&#10;END' />
      </column>
